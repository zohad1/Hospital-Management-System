<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="433.0" prefWidth="843.0" styleClass="dash-root"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.oop_lab_project.MainDoctorController">
    <stylesheets>
        <URL value="@styles.css"/>
    </stylesheets>

    <!-- Top Bar -->
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="60" styleClass="top-bar" spacing="14">
            <Label text="✚  MedicusPro" styleClass="nav-brand"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="Doctor" styleClass="top-bar-role"/>
            <Label text="|" styleClass="top-bar-sep"/>
            <Button fx:id="logOutButton" text="Log Out" styleClass="btn-logout"
                    onAction="#handleLogOut"/>
            <Button fx:id="exitButton" text="Exit" styleClass="btn-exit-sm"
                    onAction="#handleExit"/>
        </HBox>
    </top>

    <!-- Main Content -->
    <center>
        <VBox styleClass="dash-content" spacing="24">

            <!-- Welcome Header -->
            <VBox spacing="4">
                <Label text="Doctor Dashboard" styleClass="dash-welcome-title"/>
                <Label text="Manage your patients and appointments"
                       styleClass="dash-welcome-sub"/>
            </VBox>

            <!-- Divider -->
            <Region styleClass="dash-divider" maxWidth="1e9"/>

            <!-- Action Cards -->
            <TilePane alignment="CENTER" hgap="24" vgap="20" prefColumns="2">

                <Button fx:id="managePatientsButton" onAction="#handleManagePatients"
                        styleClass="dash-card" prefWidth="240" prefHeight="165"
                        contentDisplay="GRAPHIC_ONLY">
                    <graphic>
                        <VBox alignment="CENTER" spacing="10" prefWidth="200">
                            <Label text="&#128203;" styleClass="dash-card-icon"/>
                            <Label text="Manage Patients" styleClass="dash-card-title"
                                   maxWidth="180" wrapText="true" textAlignment="CENTER"/>
                            <Label text="View and update patient records"
                                   styleClass="dash-card-desc" maxWidth="180" wrapText="true"
                                   textAlignment="CENTER"/>
                        </VBox>
                    </graphic>
                </Button>

                <Button fx:id="appointmentsButton" onAction="#handleAppointments"
                        styleClass="dash-card" prefWidth="240" prefHeight="165"
                        contentDisplay="GRAPHIC_ONLY">
                    <graphic>
                        <VBox alignment="CENTER" spacing="10" prefWidth="200">
                            <Label text="&#128197;" styleClass="dash-card-icon"/>
                            <Label text="Appointments" styleClass="dash-card-title"
                                   maxWidth="180" wrapText="true" textAlignment="CENTER"/>
                            <Label text="View and manage your appointments"
                                   styleClass="dash-card-desc" maxWidth="180" wrapText="true"
                                   textAlignment="CENTER"/>
                        </VBox>
                    </graphic>
                </Button>

            </TilePane>
        </VBox>
    </center>
</BorderPane>
