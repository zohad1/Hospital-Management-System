<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="550.0" prefWidth="960.0" styleClass="dash-root"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.oop_lab_project.HistoryPatientController">
    <stylesheets>
        <URL value="@styles.css"/>
    </stylesheets>

    <!-- Header -->
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="55" styleClass="top-bar" spacing="14">
            <Button text="← Back" styleClass="btn-back" onAction="#handleBack"/>
            <Label text="✚  MedicusPro" styleClass="nav-brand"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="Appointment History" styleClass="page-title"/>
        </HBox>
    </top>

    <!-- Content -->
    <center>
        <VBox styleClass="content-area" spacing="14">

            <VBox spacing="4">
                <Label text="My Appointment History" styleClass="section-label"/>
                <Label text="Search by name to view your past appointments"
                       styleClass="section-sub"/>
            </VBox>

            <!-- Search Bar -->
            <HBox styleClass="update-bar" spacing="14" alignment="CENTER_LEFT">
                <Label text="Search by Name:" styleClass="update-bar-label"/>
                <TextField fx:id="nameField" prefHeight="38" prefWidth="260"
                           promptText="Enter your name" styleClass="form-input"/>
                <Button text="Search" styleClass="btn-primary" prefHeight="38"
                        prefWidth="100" onAction="#handleSearch"/>
            </HBox>

            <!-- Results Table -->
            <TableView fx:id="appointmentTable" styleClass="data-table" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="columnId" text="P-ID" prefWidth="60"/>
                    <TableColumn fx:id="columnName" text="Name" prefWidth="100"/>
                    <TableColumn fx:id="columnGender" text="Gender" prefWidth="70"/>
                    <TableColumn fx:id="columnIssue" text="Issue" prefWidth="100"/>
                    <TableColumn fx:id="columnMedicalHistory" text="Medical History" prefWidth="130"/>
                    <TableColumn fx:id="columnMedications" text="Medications" prefWidth="115"/>
                    <TableColumn fx:id="columnRoom" text="Room" prefWidth="65"/>
                    <TableColumn fx:id="columnTime" text="Time" prefWidth="100"/>
                    <TableColumn fx:id="columnStatus" text="Status" prefWidth="80"/>
                    <TableColumn fx:id="columnWard" text="Ward" prefWidth="70"/>
                    <TableColumn fx:id="columnBedNo" text="Bed No." prefWidth="75"/>
                </columns>
            </TableView>

        </VBox>
    </center>
</BorderPane>
