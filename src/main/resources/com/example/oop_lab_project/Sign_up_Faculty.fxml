<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox prefHeight="490.0" prefWidth="889.0"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.oop_lab_project.SignUpFacultyController">
    <stylesheets>
        <URL value="@styles.css"/>
    </stylesheets>

    <!-- Left Branding Panel -->
    <VBox styleClass="left-panel" prefWidth="356" alignment="CENTER" spacing="18">
        <Label text="✚" style="-fx-font-size: 54px; -fx-text-fill: #0D9488;"/>
        <Label text="MedicusPro" styleClass="brand-title"/>
        <Label text="Create an account to access the hospital management portal"
               styleClass="brand-subtitle" wrapText="true" maxWidth="240" textAlignment="CENTER"/>
        <Region VBox.vgrow="ALWAYS"/>
        <Button text="← Back" styleClass="btn-back" prefWidth="130" onAction="#handleBack"/>
    </VBox>

    <!-- Right Form Panel -->
    <VBox styleClass="right-panel" HBox.hgrow="ALWAYS" alignment="CENTER" spacing="10">

        <Label text="Faculty Sign Up" styleClass="form-title"/>
        <Label text="Fill in your details to register" styleClass="form-subtitle"/>

        <!-- Spacer -->
        <Region prefHeight="4"/>

        <!-- Role -->
        <VBox spacing="5" maxWidth="340">
            <Label text="Role" styleClass="field-label"/>
            <ComboBox fx:id="roleComboBox" prefWidth="340" prefHeight="40"
                      promptText="Select Role" styleClass="form-combo"/>
        </VBox>

        <!-- Username -->
        <VBox spacing="5" maxWidth="340">
            <Label text="Username" styleClass="field-label"/>
            <TextField fx:id="usernameField" prefHeight="40" prefWidth="340"
                       promptText="Username" styleClass="form-input"/>
        </VBox>

        <!-- Password -->
        <VBox spacing="5" maxWidth="340">
            <Label text="Password" styleClass="field-label"/>
            <PasswordField fx:id="passwordField" prefHeight="40" prefWidth="340"
                           promptText="Password" styleClass="form-input"/>
        </VBox>

        <!-- Department -->
        <VBox spacing="5" maxWidth="340">
            <Label text="Department" styleClass="field-label"/>
            <TextField fx:id="departmentField" prefHeight="40" prefWidth="340"
                       promptText="Department" styleClass="form-input"/>
        </VBox>

        <!-- Gender + Contact side by side -->
        <HBox spacing="12" maxWidth="340">
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Gender" styleClass="field-label"/>
                <TextField fx:id="genderField" prefHeight="40" prefWidth="164"
                           promptText="Gender" styleClass="form-input"/>
            </VBox>
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Contact" styleClass="field-label"/>
                <TextField fx:id="contactField" prefHeight="40" prefWidth="164"
                           promptText="Contact No." styleClass="form-input"/>
            </VBox>
        </HBox>

        <!-- Spacer -->
        <Region prefHeight="4"/>

        <!-- Buttons -->
        <HBox spacing="12" maxWidth="340" alignment="CENTER">
            <Button fx:id="logInButton" text="Log In" styleClass="btn-secondary"
                    prefWidth="162" prefHeight="42" onAction="#handleLogIn"/>
            <Button fx:id="signUpButton" text="Sign Up" styleClass="btn-primary"
                    prefWidth="162" prefHeight="42" onAction="#handleSignUp"/>
        </HBox>

    </VBox>
</HBox>
