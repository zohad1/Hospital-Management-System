<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="550.0" prefWidth="950.0" styleClass="dash-root"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.oop_lab_project.ManageDoctorController">
    <stylesheets>
        <URL value="@styles.css"/>
    </stylesheets>

    <!-- Header -->
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="55" styleClass="top-bar" spacing="14">
            <Button text="← Back" styleClass="btn-back" onAction="#handleBack"/>
            <Label text="✚  MedicusPro" styleClass="nav-brand"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="Manage Doctors" styleClass="page-title"/>
        </HBox>
    </top>

    <!-- Content -->
    <center>
        <HBox styleClass="content-area" spacing="20">

            <!-- Table -->
            <VBox spacing="10" HBox.hgrow="ALWAYS">
                <Label text="Doctor Records" styleClass="section-label"/>
                <TableView fx:id="doctorTable" styleClass="data-table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="columnName" text="Name" prefWidth="120"/>
                        <TableColumn fx:id="columnDepartment" text="Department" prefWidth="140"/>
                        <TableColumn fx:id="columnGender" text="Gender" prefWidth="90"/>
                        <TableColumn fx:id="columnContact" text="Contact" prefWidth="120"/>
                    </columns>
                </TableView>
            </VBox>

            <!-- Form Panel -->
            <VBox styleClass="action-panel" prefWidth="275" spacing="10">
                <Label text="Edit Record" styleClass="section-label"/>
                <Label text="Fill fields to insert, or select a row to update/delete"
                       styleClass="section-sub" wrapText="true"/>

                <Region prefHeight="6"/>

                <TextField fx:id="nameField" prefHeight="38" promptText="Name"
                           styleClass="form-input"/>
                <TextField fx:id="departmentField" prefHeight="38" promptText="Department"
                           styleClass="form-input"/>
                <TextField fx:id="genderField" prefHeight="38" promptText="Gender"
                           styleClass="form-input"/>
                <TextField fx:id="contactField" prefHeight="38" promptText="Contact"
                           styleClass="form-input"/>

                <Region VBox.vgrow="ALWAYS"/>

                <Button text="Insert" styleClass="btn-primary" prefHeight="38"
                        maxWidth="1e9" onAction="#handleInsert"/>
                <Button text="Update" styleClass="btn-secondary" prefHeight="38"
                        maxWidth="1e9" onAction="#handleUpdate"/>
                <Button text="Delete" styleClass="btn-danger" prefHeight="38"
                        maxWidth="1e9" onAction="#handleDelete"/>
            </VBox>

        </HBox>
    </center>
</BorderPane>
