<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="490.0" prefWidth="830.0" styleClass="auth-root"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.oop_lab_project.loginsignupallController">
    <stylesheets>
        <URL value="@styles.css"/>
    </stylesheets>

    <center>
        <VBox alignment="CENTER" spacing="28">

            <!-- Header -->
            <Label text="HOSPITAL MANAGEMENT SYSTEM" styleClass="form-title"/>
            <Label text="Please select your role to continue" styleClass="form-subtitle"/>

            <!-- Role Cards -->
            <HBox alignment="CENTER" spacing="32">

                <Button fx:id="facultyLoginButton" onAction="#handleFacultyLogin"
                        styleClass="role-card" prefWidth="190" prefHeight="150"
                        contentDisplay="GRAPHIC_ONLY">
                    <graphic>
                        <VBox alignment="CENTER" spacing="10">
                            <Label text="&#128100;" style="-fx-font-size: 38px;"/>
                            <Label text="Faculty Login" styleClass="role-card-title"/>
                            <Label text="Admin  ·  Doctor  ·  Nurse" styleClass="role-card-sub"/>
                        </VBox>
                    </graphic>
                </Button>

                <Button fx:id="patientLoginButton" onAction="#handlePatientLogin"
                        styleClass="role-card" prefWidth="190" prefHeight="150"
                        contentDisplay="GRAPHIC_ONLY">
                    <graphic>
                        <VBox alignment="CENTER" spacing="10">
                            <Label text="&#9829;" style="-fx-font-size: 38px; -fx-text-fill: #0D9488;"/>
                            <Label text="Patient Login" styleClass="role-card-title"/>
                            <Label text="Book &amp; Track Appointments" styleClass="role-card-sub"/>
                        </VBox>
                    </graphic>
                </Button>

            </HBox>

            <!-- Actions -->
            <HBox alignment="CENTER" spacing="16">
                <Button text="← Back" styleClass="btn-secondary" prefWidth="120" prefHeight="38"
                        onAction="#handleBack"/>
                <Button text="Exit" styleClass="btn-exit" prefWidth="120" prefHeight="38"
                        onAction="#handleExit"/>
            </HBox>

        </VBox>
    </center>
</BorderPane>
