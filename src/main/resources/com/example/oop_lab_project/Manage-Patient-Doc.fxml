<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="550.0" prefWidth="1000.0" styleClass="dash-root"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.oop_lab_project.ManagePatientDocController">
    <stylesheets>
        <URL value="@styles.css"/>
    </stylesheets>

    <!-- Header -->
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="55" styleClass="top-bar" spacing="14">
            <Button text="← Back" styleClass="btn-back" onAction="#handleBack"/>
            <Label text="✚  MedicusPro" styleClass="nav-brand"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="Manage Patients" styleClass="page-title"/>
        </HBox>
    </top>

    <!-- Content -->
    <center>
        <HBox styleClass="content-area" spacing="16">

            <!-- Table -->
            <VBox spacing="8" HBox.hgrow="ALWAYS">
                <Label text="Patient Records" styleClass="section-label"/>
                <Label text="Select a patient to update their medical details"
                       styleClass="section-sub"/>
                <TableView fx:id="appointmentTable" styleClass="data-table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="columnId" text="P-ID" prefWidth="65"/>
                        <TableColumn fx:id="columnName" text="Name" prefWidth="110"/>
                        <TableColumn fx:id="columnIssue" text="Issue" prefWidth="110"/>
                        <TableColumn fx:id="columnMedicalHistory" text="Medical History" prefWidth="140"/>
                        <TableColumn fx:id="columnMedication" text="Medications" prefWidth="120"/>
                        <TableColumn fx:id="columnGender" text="Gender" prefWidth="75"/>
                        <TableColumn fx:id="columnStatus" text="Status" prefWidth="85"/>
                        <TableColumn fx:id="columnWard" text="Ward" prefWidth="70"/>
                        <TableColumn fx:id="columnBedNo" text="Bed No." prefWidth="75"/>
                    </columns>
                </TableView>
            </VBox>

            <!-- Action Panel -->
            <VBox styleClass="action-panel" spacing="12" prefWidth="260">
                <Label text="Update Patient" styleClass="section-label"/>
                <Label text="Select a patient and edit their details" styleClass="section-sub"/>

                <Region prefHeight="6"/>

                <Label text="Issue" styleClass="field-label"/>
                <TextField fx:id="issueField" prefHeight="40" prefWidth="220"
                           promptText="Issue" styleClass="form-input"/>

                <Label text="Status" styleClass="field-label"/>
                <TextField fx:id="statusField" prefHeight="40" prefWidth="220"
                           promptText="Status" styleClass="form-input"/>

                <Label text="Medications" styleClass="field-label"/>
                <TextField fx:id="medicationField" prefHeight="40" prefWidth="220"
                           promptText="Medications" styleClass="form-input"/>

                <Label text="Ward" styleClass="field-label"/>
                <TextField fx:id="wardField" prefHeight="40" prefWidth="220"
                           promptText="Ward" styleClass="form-input"/>

                <Label text="Bed No." styleClass="field-label"/>
                <TextField fx:id="bedNoField" prefHeight="40" prefWidth="220"
                           promptText="Bed No." styleClass="form-input"/>

                <Region prefHeight="4"/>

                <Button text="Update Patient" styleClass="btn-primary" prefHeight="40"
                        maxWidth="1e9" onAction="#handleUpdate"/>
            </VBox>

        </HBox>
    </center>
</BorderPane>
