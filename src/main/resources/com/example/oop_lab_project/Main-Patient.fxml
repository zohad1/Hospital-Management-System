<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="478.0" prefWidth="686.0" styleClass="dash-root"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.oop_lab_project.MainPatientController">
    <stylesheets>
        <URL value="@styles.css"/>
    </stylesheets>

    <!-- Top Bar -->
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="60" styleClass="top-bar" spacing="14">
            <Label text="✚  MedicusPro" styleClass="nav-brand"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="Patient Portal" styleClass="top-bar-role"/>
            <Label text="|" styleClass="top-bar-sep"/>
            <Button fx:id="logoutButton" text="Log Out" styleClass="btn-logout"
                    onAction="#handleLogout"/>
        </HBox>
    </top>

    <!-- Main Content -->
    <center>
        <VBox styleClass="dash-content" spacing="24">

            <!-- Welcome Header -->
            <VBox spacing="4">
                <Label text="Patient Dashboard" styleClass="dash-welcome-title"/>
                <Label text="Book appointments and view your medical history"
                       styleClass="dash-welcome-sub"/>
            </VBox>

            <!-- Divider -->
            <Region styleClass="dash-divider" maxWidth="1e9"/>

            <!-- Action Cards -->
            <TilePane alignment="CENTER" hgap="24" vgap="20" prefColumns="2">

                <Button fx:id="appointmentButton" onAction="#handleAppointment"
                        styleClass="dash-card" prefWidth="230" prefHeight="165"
                        contentDisplay="GRAPHIC_ONLY">
                    <graphic>
                        <VBox alignment="CENTER" spacing="10" prefWidth="190">
                            <Label text="&#128197;" styleClass="dash-card-icon"/>
                            <Label text="Book Appointment" styleClass="dash-card-title"
                                   maxWidth="170" wrapText="true" textAlignment="CENTER"/>
                            <Label text="Schedule a visit with a doctor"
                                   styleClass="dash-card-desc" maxWidth="170" wrapText="true"
                                   textAlignment="CENTER"/>
                        </VBox>
                    </graphic>
                </Button>

                <Button fx:id="historyButton" onAction="#handleHistory"
                        styleClass="dash-card" prefWidth="230" prefHeight="165"
                        contentDisplay="GRAPHIC_ONLY">
                    <graphic>
                        <VBox alignment="CENTER" spacing="10" prefWidth="190">
                            <Label text="&#128221;" styleClass="dash-card-icon"/>
                            <Label text="View History" styleClass="dash-card-title"
                                   maxWidth="170" wrapText="true" textAlignment="CENTER"/>
                            <Label text="Review your past appointments"
                                   styleClass="dash-card-desc" maxWidth="170" wrapText="true"
                                   textAlignment="CENTER"/>
                        </VBox>
                    </graphic>
                </Button>

            </TilePane>
        </VBox>
    </center>
</BorderPane>
