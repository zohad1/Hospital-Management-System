<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox prefHeight="490.0" prefWidth="889.0"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.oop_lab_project.LoginFacultyController">
    <stylesheets>
        <URL value="@styles.css"/>
    </stylesheets>

    <!-- Left Branding Panel -->
    <VBox styleClass="left-panel" prefWidth="356" alignment="CENTER" spacing="18">
        <Label text="✚" style="-fx-font-size: 54px; -fx-text-fill: #0D9488;"/>
        <Label text="MedicusPro" styleClass="brand-title"/>
        <Label text="Shifa International Hospital Management System"
               styleClass="brand-subtitle" wrapText="true" maxWidth="240" textAlignment="CENTER"/>
        <Region VBox.vgrow="ALWAYS"/>
        <Button text="← Back" styleClass="btn-back" prefWidth="130" onAction="#handleBack"/>
    </VBox>

    <!-- Right Form Panel -->
    <VBox styleClass="right-panel" HBox.hgrow="ALWAYS" alignment="CENTER" spacing="14">

        <Label text="Faculty Login" styleClass="form-title"/>
        <Label text="Sign in with your role and credentials" styleClass="form-subtitle"/>

        <!-- Spacer -->
        <Region prefHeight="8"/>

        <!-- Role -->
        <VBox spacing="6" maxWidth="340">
            <Label text="Role" styleClass="field-label"/>
            <ComboBox fx:id="roleComboBox" prefWidth="340" prefHeight="40" promptText="Select Role" styleClass="form-combo"/>
        </VBox>

        <!-- Username -->
        <VBox spacing="6" maxWidth="340">
            <Label text="Username" styleClass="field-label"/>
            <TextField fx:id="usernameField" prefWidth="340" prefHeight="40"
                       promptText="Enter your username" styleClass="form-input"/>
        </VBox>

        <!-- Password -->
        <VBox spacing="6" maxWidth="340">
            <Label text="Password" styleClass="field-label"/>
            <PasswordField fx:id="passwordField" prefWidth="340" prefHeight="40"
                           promptText="Enter your password" styleClass="form-input"/>
        </VBox>

        <!-- Spacer -->
        <Region prefHeight="4"/>

        <!-- Buttons -->
        <HBox spacing="12" maxWidth="340" alignment="CENTER">
            <Button fx:id="loginButton" text="Log In" styleClass="btn-primary"
                    prefWidth="162" prefHeight="42" onAction="#handleLogin"/>
            <Button fx:id="signUpButton" text="Sign Up" styleClass="btn-secondary"
                    prefWidth="162" prefHeight="42" onAction="#handleSignUp"/>
        </HBox>

    </VBox>
</HBox>
