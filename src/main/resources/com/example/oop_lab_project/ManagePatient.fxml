<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="550.0" prefWidth="1050.0" styleClass="dash-root"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.oop_lab_project.ManagePatientController">
    <stylesheets>
        <URL value="@styles.css"/>
    </stylesheets>

    <!-- Header -->
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="55" styleClass="top-bar" spacing="14">
            <Button text="← Back" styleClass="btn-back" onAction="#handleBack"/>
            <Label text="✚  MedicusPro" styleClass="nav-brand"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="Manage Patients" styleClass="page-title"/>
        </HBox>
    </top>

    <!-- Content -->
    <center>
        <HBox styleClass="content-area" spacing="20">

            <!-- Table -->
            <VBox spacing="10" HBox.hgrow="ALWAYS">
                <Label text="Patient Appointment Records" styleClass="section-label"/>
                <TableView fx:id="appointmentTable" styleClass="data-table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="columnId" text="P-ID" prefWidth="55"/>
                        <TableColumn fx:id="columnName" text="Name" prefWidth="90"/>
                        <TableColumn fx:id="columnGender" text="Gender" prefWidth="65"/>
                        <TableColumn fx:id="columnIssue" text="Issue" prefWidth="90"/>
                        <TableColumn fx:id="columnMedicalHistory" text="Med. History" prefWidth="110"/>
                        <TableColumn fx:id="columnMedications" text="Medications" prefWidth="100"/>
                        <TableColumn fx:id="columnRoom" text="Room" prefWidth="60"/>
                        <TableColumn fx:id="columnTime" text="Time" prefWidth="90"/>
                        <TableColumn fx:id="columnStatus" text="Status" prefWidth="80"/>
                        <TableColumn fx:id="columnWard" text="Ward" prefWidth="65"/>
                        <TableColumn fx:id="columnBedNo" text="Bed No." prefWidth="70"/>
                    </columns>
                </TableView>
            </VBox>

            <!-- Scrollable Form Panel -->
            <VBox styleClass="action-panel" prefWidth="285" spacing="0">
                <Label text="Edit Record" styleClass="section-label"/>
                <Label text="Select a row or fill in fields below"
                       styleClass="section-sub" wrapText="true"/>

                <Region prefHeight="10"/>

                <ScrollPane styleClass="action-scroll" fitToWidth="true" VBox.vgrow="ALWAYS">
                    <content>
                        <VBox spacing="8" style="-fx-background-color: transparent;">
                            <TextField fx:id="idField" prefHeight="36" promptText="P-ID"
                                       styleClass="form-input"/>
                            <TextField fx:id="nameField" prefHeight="36" promptText="Name"
                                       styleClass="form-input"/>
                            <TextField fx:id="genderField" prefHeight="36" promptText="Gender"
                                       styleClass="form-input"/>
                            <TextField fx:id="issueField" prefHeight="36" promptText="Issue"
                                       styleClass="form-input"/>
                            <TextField fx:id="medicalHistoryField" prefHeight="36"
                                       promptText="Medical History" styleClass="form-input"/>
                            <TextField fx:id="medicationsField" prefHeight="36"
                                       promptText="Medications" styleClass="form-input"/>
                            <TextField fx:id="roomField" prefHeight="36" promptText="Room"
                                       styleClass="form-input"/>
                            <HBox spacing="8">
                                <DatePicker fx:id="datePicker" prefHeight="36" prefWidth="148"
                                            promptText="Date"/>
                                <TextField fx:id="timeField" prefHeight="36" prefWidth="80"
                                           promptText="HH:MM:SS" styleClass="form-input"/>
                            </HBox>
                            <TextField fx:id="statusField" prefHeight="36" promptText="Status"
                                       styleClass="form-input"/>
                            <TextField fx:id="wardField" prefHeight="36" promptText="Ward No."
                                       styleClass="form-input"/>
                            <TextField fx:id="bedNoField" prefHeight="36" promptText="Bed Number"
                                       styleClass="form-input"/>
                        </VBox>
                    </content>
                </ScrollPane>

                <Region prefHeight="10"/>

                <Button text="Insert" styleClass="btn-primary" prefHeight="36"
                        maxWidth="1e9" onAction="#handleInsert"/>
                <Region prefHeight="6"/>
                <Button text="Update" styleClass="btn-secondary" prefHeight="36"
                        maxWidth="1e9" onAction="#handleUpdate"/>
                <Region prefHeight="6"/>
                <Button text="Delete" styleClass="btn-danger" prefHeight="36"
                        maxWidth="1e9" onAction="#handleDelete"/>
            </VBox>

        </HBox>
    </center>
</BorderPane>
