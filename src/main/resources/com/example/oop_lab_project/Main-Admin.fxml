<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="550.0" prefWidth="900.0" styleClass="dash-root"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.oop_lab_project.MainAdminController">
    <stylesheets>
        <URL value="@styles.css"/>
    </stylesheets>

    <!-- Top Bar -->
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="60" styleClass="top-bar" spacing="14">
            <Label text="✚  MedicusPro" styleClass="nav-brand"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="Administrator" styleClass="top-bar-role"/>
            <Label text="|" styleClass="top-bar-sep"/>
            <Button fx:id="logoutButton" text="Log Out" styleClass="btn-logout"
                    onAction="#handleLogout"/>
        </HBox>
    </top>

    <!-- Main Content -->
    <center>
        <VBox styleClass="dash-content" spacing="24">

            <!-- Welcome Header -->
            <VBox spacing="4">
                <Label text="Admin Dashboard" styleClass="dash-welcome-title"/>
                <Label text="Manage all hospital operations from one place"
                       styleClass="dash-welcome-sub"/>
            </VBox>

            <!-- Divider -->
            <Region styleClass="dash-divider" maxWidth="1e9"/>

            <!-- Action Cards -->
            <TilePane alignment="CENTER" hgap="20" vgap="20" prefColumns="3">

                <Button fx:id="manageDoctorButton" onAction="#handleManageDoctor"
                        styleClass="dash-card" prefWidth="210" prefHeight="155"
                        contentDisplay="GRAPHIC_ONLY">
                    <graphic>
                        <VBox alignment="CENTER" spacing="10" prefWidth="170">
                            <Label text="&#128104;" styleClass="dash-card-icon"/>
                            <Label text="Manage Doctors" styleClass="dash-card-title"
                                   maxWidth="160" wrapText="true" textAlignment="CENTER"/>
                            <Label text="Add, edit &amp; remove doctors"
                                   styleClass="dash-card-desc" maxWidth="160" wrapText="true"
                                   textAlignment="CENTER"/>
                        </VBox>
                    </graphic>
                </Button>

                <Button fx:id="manageNurseButton" onAction="#handleManageNurse"
                        styleClass="dash-card" prefWidth="210" prefHeight="155"
                        contentDisplay="GRAPHIC_ONLY">
                    <graphic>
                        <VBox alignment="CENTER" spacing="10" prefWidth="170">
                            <Label text="&#128105;" styleClass="dash-card-icon"/>
                            <Label text="Manage Nurses" styleClass="dash-card-title"
                                   maxWidth="160" wrapText="true" textAlignment="CENTER"/>
                            <Label text="Add, edit &amp; remove nurses"
                                   styleClass="dash-card-desc" maxWidth="160" wrapText="true"
                                   textAlignment="CENTER"/>
                        </VBox>
                    </graphic>
                </Button>

                <Button fx:id="managePatientButton" onAction="#handleManagePatient"
                        styleClass="dash-card" prefWidth="210" prefHeight="155"
                        contentDisplay="GRAPHIC_ONLY">
                    <graphic>
                        <VBox alignment="CENTER" spacing="10" prefWidth="170">
                            <Label text="&#127973;" styleClass="dash-card-icon"/>
                            <Label text="Manage Patients" styleClass="dash-card-title"
                                   maxWidth="160" wrapText="true" textAlignment="CENTER"/>
                            <Label text="View &amp; manage patient records"
                                   styleClass="dash-card-desc" maxWidth="160" wrapText="true"
                                   textAlignment="CENTER"/>
                        </VBox>
                    </graphic>
                </Button>

                <Button fx:id="manageAppointmentTimeButton"
                        onAction="#handleManageAppointmentTime"
                        styleClass="dash-card" prefWidth="210" prefHeight="155"
                        contentDisplay="GRAPHIC_ONLY">
                    <graphic>
                        <VBox alignment="CENTER" spacing="10" prefWidth="170">
                            <Label text="&#128197;" styleClass="dash-card-icon"/>
                            <Label text="Appointments" styleClass="dash-card-title"
                                   maxWidth="160" wrapText="true" textAlignment="CENTER"/>
                            <Label text="Manage appointment schedules"
                                   styleClass="dash-card-desc" maxWidth="160" wrapText="true"
                                   textAlignment="CENTER"/>
                        </VBox>
                    </graphic>
                </Button>

                <Button fx:id="manageRoomsButton" onAction="#handleManageRooms"
                        styleClass="dash-card" prefWidth="210" prefHeight="155"
                        contentDisplay="GRAPHIC_ONLY">
                    <graphic>
                        <VBox alignment="CENTER" spacing="10" prefWidth="170">
                            <Label text="&#128719;" styleClass="dash-card-icon"/>
                            <Label text="Manage Rooms" styleClass="dash-card-title"
                                   maxWidth="160" wrapText="true" textAlignment="CENTER"/>
                            <Label text="Room and ward assignments"
                                   styleClass="dash-card-desc" maxWidth="160" wrapText="true"
                                   textAlignment="CENTER"/>
                        </VBox>
                    </graphic>
                </Button>

                <Button fx:id="viewPerformanceButton" onAction="#handleViewPerformance"
                        styleClass="dash-card" prefWidth="210" prefHeight="155"
                        contentDisplay="GRAPHIC_ONLY">
                    <graphic>
                        <VBox alignment="CENTER" spacing="10" prefWidth="170">
                            <Label text="&#128202;" styleClass="dash-card-icon"/>
                            <Label text="Performance" styleClass="dash-card-title"
                                   maxWidth="160" wrapText="true" textAlignment="CENTER"/>
                            <Label text="View staff performance reports"
                                   styleClass="dash-card-desc" maxWidth="160" wrapText="true"
                                   textAlignment="CENTER"/>
                        </VBox>
                    </graphic>
                </Button>

            </TilePane>
        </VBox>
    </center>
</BorderPane>
